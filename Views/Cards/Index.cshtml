@using System.Linq
@model IEnumerable<Dự_Án_CNPM.Models.Card>

@{
    ViewData["Title"] = "Quản lý Thẻ";
}

<div class="container-fluid py-2">
    <div class="d-flex align-items-center justify-content-between mb-5">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-0">Hệ Thống Thẻ RFID</h1>
            <p class="text-muted opacity-75 mb-0">Quản lý kho thẻ từ và quyền truy cập vận hành.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-5 py-3 shadow-lg fw-bold">
                <i class="bi bi-plus-lg me-2"></i> CẤP THẺ MỚI
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th class="ps-4">Mã Thẻ (UID)</th>
                    <th>Trạng Thái</th>
                    <th>Ghi Chú</th>
                    <th class="text-center">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-primary">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-credit-card-2-front me-3 fs-5 opacity-50"></i>
                                @item.CardId
                            </div>
                        </td>
                        <td>
                            @if (item.Status == "Available")
                            {
                                <span class="badge bg-success shadow-sm rounded-pill px-3 py-2">
                                    <i class="bi bi-check-circle-fill me-1"></i> SẴN SÀNG
                                </span>
                            }
                            else if (item.Status == "InUse")
                            {
                                <span class="badge bg-warning text-dark shadow-sm rounded-pill px-3 py-2">
                                    <i class="bi bi-clock-fill me-1"></i> ĐANG DÙNG
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger shadow-sm rounded-pill px-3 py-2">
                                    <i class="bi bi-lock-fill me-1"></i> ĐÃ KHÓA
                                </span>
                            }
                        </td>
                        <td class="text-muted">@(string.IsNullOrEmpty(item.Note) ? "-" : item.Note)</td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
                                @if (item.Status != "Locked")
                                {
                                    <form asp-action="Lock" asp-route-id="@item.CardId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-white btn-sm px-3 py-2 border-0" title="Khóa thẻ">
                                            <i class="bi bi-lock text-danger"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Unlock" asp-route-id="@item.CardId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-white btn-sm px-3 py-2 border-0" title="Kích hoạt thẻ">
                                            <i class="bi bi-unlock text-success"></i>
                                        </button>
                                    </form>
                                }
                                <a asp-action="Edit" asp-route-id="@item.CardId" class="btn btn-white btn-sm px-3 py-2 border-0" title="Sửa">
                                    <i class="bi bi-pencil text-primary"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.CardId" method="post" class="d-inline" onsubmit="return confirm('Xác nhận xóa thẻ này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-white btn-sm px-3 py-2 border-0" title="Xóa">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model == null || !((IEnumerable<dynamic>)Model).Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox text-muted opacity-25" style="font-size: 5rem;"></i>
            <h5 class="text-muted mt-3">Danh sách trống</h5>
        </div>
    }
</div>
