@model Dự_Án_CNPM.Models.Subscription

@{
    ViewData["Title"] = "Chi tiết vé tháng";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Chi tiết thông tin đăng ký</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">Tên khách hàng</div>
                        <div class="col-sm-8 fw-bold">@Model.CustomerName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Số điện thoại</div>
                        <div class="col-sm-8">@Model.PhoneNumber</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Biển số xe</div>
                        <div class="col-sm-8"><span class="badge bg-dark fs-6">@Model.LicensePlate</span></div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Loại xe</div>
                        <div class="col-sm-8">@Model.VehicleType</div>
                    </div>
                    <hr />
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Ngày bắt đầu</div>
                        <div class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Ngày hết hạn</div>
                        <div class="col-sm-8">@Model.EndDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">Trạng thái thẻ</div>
                        <div class="col-sm-8">
                            @if (Model.IsActive && Model.EndDate >= DateTime.Now)
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Không hoạt động / Hết hạn</span>
                            }
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-md-2">
                            <i class="bi bi-pencil"></i> Sửa thông tin
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
