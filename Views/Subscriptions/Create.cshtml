@model Dự_Án_CNPM.Models.Subscription

@{
    ViewData["Title"] = "Đăng ký vé tháng";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Đăng ký vé tháng mới</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="CustomerName" class="form-label">Tên khách hàng</label>
                            <input asp-for="CustomerName" class="form-control" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="0901234567" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="LicensePlate" class="form-label">Biển số xe</label>
                            <input asp-for="LicensePlate" class="form-control text-uppercase" placeholder="29A-123.45" />
                            <span asp-validation-for="LicensePlate" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="VehicleType" class="form-label">Loại xe</label>
                            <select asp-for="VehicleType" class="form-select">
                                <option value="Car">Ô tô (Car)</option>
                                <option value="Motorbike">Xe máy (Motorbike)</option>
                                <option value="Truck">Xe tải (Truck)</option>
                            </select>
                            <span asp-validation-for="VehicleType" class="text-danger"></span>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label">Ngày bắt đầu</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label">Ngày hết hạn</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                            <label class="form-check-label" asp-for="IsActive">Kích hoạt thẻ</label>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Lưu đăng ký
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
