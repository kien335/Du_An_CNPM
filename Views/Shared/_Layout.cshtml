<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parking System PRO</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/Dự_Án_CNPM.styles.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar -->
        <aside id="sidebar">
            <div class="d-flex align-items-center mb-4 px-3">
                <div class="bg-primary rounded-3 p-2 me-3 shadow-sm" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-p-square-fill text-white fs-4"></i>
                </div>
                <div>
                    <h5 class="mb-0 text-white brand-text">PARKING <span class="text-primary-cyan">PRO</span></h5>
                    <small class="text-light opacity-50 x-small">Management System</small>
                </div>
            </div>

            <nav class="nav flex-column">
                <div class="nav-group-title">Vận Hành</div>
                <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "") mb-2" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2 me-2"></i> <span>Dashboard</span>
                </a>
                <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "ParkingSessions" ? "active" : "") mb-2" asp-controller="ParkingSessions" asp-action="Index">
                    <i class="bi bi-car-front me-2"></i> <span>Xe vào / Xe ra</span>
                </a>
                <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["Action"]?.ToString() == "Map" ? "active" : "") mb-2" asp-controller="ParkingSlots" asp-action="Map">
                    <i class="bi bi-grid-3x3-gap me-2"></i> <span>Sơ đồ bãi xe</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="nav-group-title">Quản Lý</div>
                    <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PricingRules" ? "active" : "") mb-2" asp-controller="PricingRules" asp-action="Index">
                        <i class="bi bi-currency-dollar me-2"></i> <span>Cấu hình giá</span>
                    </a>
                    <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Subscriptions" ? "active" : "") mb-2" asp-controller="Subscriptions" asp-action="Index">
                        <i class="bi bi-person-vcard me-2"></i> <span>Khách vé tháng</span>
                    </a>
                    <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cards" ? "active" : "") mb-2" asp-controller="Cards" asp-action="Index">
                        <i class="bi bi-credit-card-2-front me-2"></i> <span>Quản lý thẻ</span>
                    </a>
                }
            </nav>

            <div class="mt-auto pt-5 border-top border-secondary opacity-75" style="position: absolute; bottom: 1.5rem; width: 85%;">
                <div class="small mb-3 px-3">
                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                </div>
                <a class="nav-link nav-link-custom text-danger" asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right me-2 text-danger"></i> <span>Đăng xuất</span>
                </a>
            </div>
        </aside>

        <div id="main-content">
            <header class="d-lg-none py-3 mb-3 d-flex align-items-center justify-content-between px-3 glass-panel">
                <button class="btn btn-outline-light border-0" onclick="toggleSidebar()"><i class="bi bi-list fs-3"></i></button>
                <h5 class="mb-0 text-white">Parking PRO</h5>
                <div style="width: 40px;"></div>
            </header>
            
            <main role="main" class="main-content-tray">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
            @RenderBody()
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('active');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

