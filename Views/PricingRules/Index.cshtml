@model IEnumerable<Dự_Án_CNPM.Models.PricingRule>

@{
    ViewData["Title"] = "Index";
}

<div class="container-fluid py-2">
    <div class="d-flex align-items-center justify-content-between mb-5">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-0">Cấu Hình Giá Gửi Xe</h1>
            <p class="text-muted opacity-75 mb-0">Thiết lập đơn giá theo loại phương tiện.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-5 py-3 shadow-lg fw-bold">
                <i class="bi bi-plus-lg me-2"></i> THÊM CẤU HÌNH
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th class="ps-4">Loại Phương Tiện</th>
                    <th>Giá Cơ Bản (VND)</th>
                    <th>Đơn Giá Giờ (VND)</th>
                    <th class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4 fw-bold text-primary">
                            <i class="bi bi-car-front-fill me-2 fs-5"></i> @item.VehicleType
                        </td>
                        <td class="fw-bold fs-5">@item.BasePrice.ToString("N0") đ</td>
                        <td class="text-info fw-bold fs-5">@item.HourlyRate.ToString("N0") đ</td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
                                <a asp-action="Edit" asp-route-id="@item.RuleId" class="btn btn-white btn-sm px-3 py-2 border-0" title="Sửa">
                                    <i class="bi bi-pencil text-primary"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.RuleId" class="btn btn-white btn-sm px-3 py-2 border-0" title="Chi tiết">
                                    <i class="bi bi-info-circle text-info"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.RuleId" class="btn btn-white btn-sm px-3 py-2 border-0" title="Xóa">
                                    <i class="bi bi-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
