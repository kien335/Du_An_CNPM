@model IEnumerable<Dự_Án_CNPM.Models.ParkingSession>

@{
    ViewData["Title"] = "Xe đang trong bãi";
}

<div class="container-fluid py-2">
    <div class="d-flex align-items-center justify-content-between mb-5">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-0">Điều Phối Xe Ra / Vào</h1>
            <p class="text-muted opacity-75 mb-0">Quản lý các phiên gửi xe hiện thời trong bãi.</p>
        </div>
        <div>
            <a asp-action="CheckIn" class="btn btn-primary rounded-pill px-4 py-3 shadow-lg fw-bold me-2">
                <i class="bi bi-box-arrow-in-right me-2"></i> TRẠM VÀO
            </a>
            <a asp-action="CheckOut" class="btn btn-danger rounded-pill px-4 py-3 shadow-lg fw-bold">
                <i class="bi bi-box-arrow-right me-2"></i> TRẠM RA
            </a>
        </div>
    </div>

    <!-- Advanced Search Form -->
    <div class="card border-0 shadow-sm rounded-4 mb-5 bg-light">
        <div class="card-body p-4">
            <h5 class="card-title fw-bold mb-4 text-dark"><i class="bi bi-search me-2 text-primary"></i> Bộ lọc tìm kiếm</h5>
            <form method="get" class="row g-4">
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-uppercase text-muted">Mã thẻ</label>
                    <input type="text" name="searchCardId" class="form-control border-0 shadow-sm" value="@ViewBag.SearchCardId" placeholder="VD: C01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-uppercase text-muted">Biển số</label>
                    <input type="text" name="searchPlate" class="form-control border-0 shadow-sm" value="@ViewBag.SearchPlate" placeholder="30A-..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-uppercase text-muted">Từ ngày</label>
                    <input type="date" name="fromDate" class="form-control border-0 shadow-sm" value="@ViewBag.FromDate" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-uppercase text-muted">Đến ngày</label>
                    <input type="date" name="toDate" class="form-control border-0 shadow-sm" value="@ViewBag.ToDate" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-uppercase text-muted">Trạng thái</label>
                    <select name="status" class="form-select border-0 shadow-sm">
                        <option value="Active" selected="@(ViewBag.CurrentStatus == "Active")">Đang trong bãi</option>
                        <option value="Completed" selected="@(ViewBag.CurrentStatus == "Completed")">Đã thanh toán</option>
                        <option value="All" selected="@(ViewBag.CurrentStatus == "All")">Tất cả</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 shadow-sm">
                        <i class="bi bi-funnel"></i> Lọc
                    </button>
                    <a asp-action="Index" class="btn btn-light rounded-pill border py-2">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["SecurityAlert"] != null)
    {
        <div class="alert alert-danger border-0 shadow-lg rounded-4 p-4 mb-5 animate__animated animate__shakeX">
            <div class="row align-items-center">
                <div class="col-md-auto">
                    <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 80px; height: 80px;">
                        <i class="bi bi-shield-exclamation fs-1"></i>
                    </div>
                </div>
                <div class="col">
                    <h3 class="fw-bold mb-1 text-danger">PHÁT HIỆN BIỂN SỐ KHÔNG KHỚP!</h3>
                    <p class="mb-0 fs-5 text-dark">Thẻ <strong>@TempData["AlertCardId"]</strong> đang được yêu cầu thoát bãi nhưng thông tin không trùng khớp với lúc vào.</p>
                </div>
                <div class="col-md-auto">
                    <form asp-action="CheckOut" method="post">
                        <input type="hidden" name="cardId" value="@TempData["AlertCardId"]" />
                        <input type="hidden" name="forceCheckOut" value="true" />
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 shadow fw-bold">BỎ QUA & CHO RA</button>
                    </form>
                </div>
            </div>
            <hr class="my-4 opacity-10">
            <div class="row text-center g-4">
                <div class="col-md-4">
                    <div class="p-3 bg-white rounded-4 shadow-sm h-100">
                        <span class="d-block text-muted small fw-bold text-uppercase mb-2">Biển số lúc vào</span>
                        <span class="display-6 fw-bold text-dark">@TempData["OriginalPlate"]</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 bg-danger text-white rounded-4 shadow-sm h-100">
                        <span class="d-block small fw-bold text-uppercase mb-2 opacity-75">Biển số quét được lúc ra</span>
                        <span class="display-6 fw-bold text-white">@TempData["ScannedPlate"]</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 bg-white rounded-4 shadow-sm h-100">
                        <span class="d-block text-muted small fw-bold text-uppercase mb-2">Loại xe</span>
                        <div class="d-flex justify-content-center gap-2">
                            <span class="badge bg-secondary px-3">Vào: @TempData["OriginalType"]</span>
                            <span class="badge bg-danger px-3">Ra: @TempData["ScannedType"]</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script>
            // Play alarm sound if possible
            window.addEventListener('load', () => {
                const AudioCtx = window.AudioContext || window.webkitAudioContext;
                const ctx = new AudioCtx();
                const osc = ctx.createOscillator();
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(440, ctx.currentTime);
                osc.connect(ctx.destination);
                osc.start();
                osc.stop(ctx.currentTime + 0.5);
            });
        </script>
    }

    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th class="ps-4">Thẻ</th>
                    <th>Biển số</th>
                    <th>Loại xe</th>
                    <th>Vị trí</th>
                    <th>Thời gian Vào</th>
                    <th>Ảnh vào</th>
                    <th class="text-end">Tạm tính</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-primary">@item.CardId</td>
                        <td>
                            <span class="badge bg-dark px-3 py-2 fs-6">@item.LicensePlate</span>
                            @if (item.IsMonthlyTicket)
                            {
                                <span class="badge bg-info-subtle text-info ms-1" style="font-size: 0.65rem;">VÉ THÁNG</span>
                            }
                        </td>
                        <td class="fw-bold">@item.VehicleType</td>
                        <td><span class="badge bg-success-subtle text-success px-3">@item.SlotId</span></td>
                        <td>
                            <div class="small fw-bold">@item.CheckInTime.ToString("HH:mm")</div>
                            <div class="text-muted x-small">@item.CheckInTime.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.CheckInImage))
                            {
                                <img src="@item.CheckInImage" alt="Xe vào" style="width: 60px; height: 40px; object-fit: cover;" class="rounded border shadow-sm cursor-zoom" onclick="window.open(this.src)">
                            }
                        </td>
                        <td class="text-end fw-bold text-primary">
                            @{
                                if (item.Status == "Active")
                                {
                                    var rules = ViewBag.PricingRules as List<Dự_Án_CNPM.Models.PricingRule>;
                                    var rule = rules?.FirstOrDefault(r => r.VehicleType == item.VehicleType);
                                    if (rule != null)
                                    {
                                        var duration = DateTime.Now - item.CheckInTime;
                                        var totalHours = (decimal)Math.Ceiling(duration.TotalHours);
                                        if (totalHours < 1) totalHours = 1;
                                        var fee = rule.BasePrice + (totalHours * rule.HourlyRate);
                                        @fee.ToString("N0") <small>đ</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-success">@item.TotalPrice?.ToString("N0") đ</span>
                                }
                            }
                        </td>
                        <td class="text-center">
                            @if (item.Status == "Active")
                            {
                                <a asp-action="CheckOut" asp-route-id="@item.CardId" class="btn btn-danger btn-sm rounded-pill px-4 shadow-sm fw-bold py-2">
                                    XUẤT BẾN <i class="bi bi-box-arrow-right ms-1"></i>
                                </a>
                            }
                            else
                            {
                                <span class="text-success small fw-bold">HOÀN TẤT</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
</div>

<!-- Modal Check-out với Plate Verification -->
<div class="modal fade" id="checkoutModal" tabindex="-1" aria-labelledby="checkoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form asp-action="CheckOut" method="post">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="checkoutModalLabel"><i class="bi bi-shield-check me-2"></i> Xác nhận xe ra</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" name="cardId" id="modalCardId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Mã thẻ</label>
                        <div id="displayCardId" class="fs-5 fw-bold text-primary mb-3"></div>
                    </div>

                    <div class="alert bg-light border-0 py-3 mb-4">
                        <div class="row align-items-center">
                            <div class="col">
                                <span class="d-block text-muted x-small text-uppercase fw-bold">Biển số đăng ký</span>
                                <span id="displayPlate" class="fs-4 fw-bold"></span>
                            </div>
                            <div class="col-auto">
                                <span id="displayType" class="badge bg-primary px-3"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-danger"><i class="bi bi-camera me-1"></i> Biển số quét được lúc ra (OCR simulation)</label>
                        <input type="text" name="currentPlate" id="currentPlateInput" class="form-control form-control-lg border-2" placeholder="VD: 30A-12345" required />
                        <div class="form-text">Nhập giống biển số đăng ký để vượt qua kiểm tra an ninh.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Phương thức thanh toán</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="radio" name="payMethod" class="btn-check" id="modalPayCash" value="Cash" checked onchange="toggleModalQR()">
                                <label class="btn btn-outline-dark w-100 py-2 fw-bold rounded-3" for="modalPayCash">
                                    <i class="bi bi-cash me-1"></i> TIỀN MẶT
                                </label>
                            </div>
                            <div class="col-6">
                                <input type="radio" name="payMethod" class="btn-check" id="modalPayQR" value="QR" onchange="toggleModalQR()">
                                <label class="btn btn-outline-dark w-100 py-2 fw-bold rounded-3" for="modalPayQR">
                                    <i class="bi bi-qr-code me-1"></i> QUÉT QR
                                </label>
                            </div>
                        </div>
                    </div>

                    <div id="modalQRTray" class="text-center p-3 border rounded-4 mb-3 d-none animate__animated animate__fadeIn">
                        <img id="modalQRImg" src="" class="img-fluid rounded shadow-sm" style="max-width: 150px;" />
                        <p class="x-small text-muted mt-2 mb-0">Quét mã để thanh toán phí gửi xe</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Loại xe kiểm tra</label>
                        <select name="currentVehicleType" id="currentTypeInput" class="form-select">
                            <option value="Car">Ô tô</option>
                            <option value="Motorbike">Xe máy</option>
                            <option value="Truck">Xe tải</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" id="btnConfirmModal" class="btn btn-danger rounded-pill px-4 shadow-sm fw-bold">
                        <i class="bi bi-check2-circle me-1"></i> XÁC NHẬN THANH TOÁN
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .bg-info-soft { background-color: rgba(13, 202, 240, 0.1); }
    .animate__animated.animate__shakeX {
        animation-duration: 0.8s;
    }
    .badge { font-weight: 600; }
</style>

<script>
    function setupCheckout(cardId, plate, type) {
        document.getElementById('modalCardId').value = cardId;
        document.getElementById('displayCardId').innerText = cardId;
        document.getElementById('displayPlate').innerText = plate;
        document.getElementById('displayType').innerText = type;
        
        document.getElementById('currentPlateInput').value = plate;
        document.getElementById('currentTypeInput').value = type;
        
        // Reset Payment State
        document.getElementById('modalPayCash').checked = true;
        document.getElementById('modalQRTray').classList.add('d-none');
    }

    function toggleModalQR() {
        const isQR = document.getElementById('modalPayQR').checked;
        const tray = document.getElementById('modalQRTray');
        if (isQR) {
            // Simulated QR Logic
            const qrUrl = `https://img.vietqr.io/image/970415-123456789-compact.png?amount=20000&addInfo=Thanh+Toan+Phi+Xe`;
            document.getElementById('modalQRImg').src = qrUrl;
            tray.classList.remove('d-none');
        } else {
            tray.classList.add('d-none');
        }
    }
</script>

</div>
